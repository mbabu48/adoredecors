# === DATABASE ===
# Local dev: SQLite file (auto-created). Production (Vercel): use Postgres URL from Neon/Supabase/Vercel Postgres.
DATABASE_URL="file:./dev.db"

# === NEXTAUTH ===
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32-char-random-string"
NEXTAUTH_URL="http://localhost:3000"

# === GOOGLE OAUTH (for admin sign-in) ===
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated list of Gmail addresses that are allowed to access /admin
ADMIN_EMAILS="officialmail.naresh@gmail.com"

# === CLOUDINARY (for event photo uploads) ===
# Sign up free at https://cloudinary.com — credentials are in your Dashboard
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Create an unsigned upload preset named "jesuraj_gallery" in Cloudinary settings
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="jesuraj_gallery"

